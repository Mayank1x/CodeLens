# =============================================================================
# CodeReview AI — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.
#
# All LLM keys come from free, no-credit-card-required signups:
#   - Gemini: https://aistudio.google.com/apikey
#   - Groq:   https://console.groq.com/keys
# =============================================================================

# --- LLM Provider API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- GitHub OAuth2 ---
# Create an OAuth App at: https://github.com/settings/developers
# Set callback URL to: http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# --- JWT Configuration ---
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_string

# --- Token Encryption ---
# Used to encrypt GitHub OAuth tokens before storing in the database.
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, tokens are stored in plaintext (acceptable for local dev only).
ENCRYPTION_KEY=

# --- Database ---
# For local dev with docker-compose, use:
DATABASE_URL=postgresql://codelens:codelens@localhost:5432/codelens

# --- Flask Configuration ---
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_SECRET_KEY=dev-secret-key-change-in-production

# --- Development Helpers ---
# Set to "true" to bypass JWT auth (creates a default test user)
# NEVER set this in production!
SKIP_AUTH=true

# --- Admin Configuration ---
# Comma-separated list of GitHub usernames who have admin access
ADMIN_USERS=your_github_username

# --- Frontend URL ---
# Used for OAuth redirects and CORS origin restriction
FRONTEND_URL=http://localhost:5173
